# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env de verdade no git

# Token do bot do Telegram (crie um via @BotFather)
TELEGRAM_BOT_TOKEN=

# ID do chat/canal do Telegram para onde as vagas serão postadas
TELEGRAM_CHAT_ID=

# Palavra-chave de busca (ex: "estagio desenvolvimento Curitiba")
SEARCH_KEYWORD=estagio desenvolvimento

# Intervalo entre execuções do scraper, em minutos
SCRAPE_INTERVAL_MINUTES=90
